    "@types/node": "^24.7.2",
    "@types/pg": "^8.15.6",
    "@types/semver": "^7.7.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
